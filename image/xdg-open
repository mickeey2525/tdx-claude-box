#!/usr/bin/env bash
# xdg-open シム: コンテナ内にブラウザはない。tcb セッションが TCB_BRIDGE
# (host:port)を設定していれば URL を1行送り、ホスト側で開いてもらう
# (OAuth の localhost コールバックはホスト側 tcb が box へ中継する)。
# ブリッジ不在・送信失敗時は URL を表示するだけ(従来動作)。
# node の `spawn xdg-open ENOENT` クラッシュ防止も引き続き兼ねる。
url="${1:-}"

if [[ -n "${TCB_BRIDGE:-}" && "$url" =~ ^https?:// ]]; then
    host="${TCB_BRIDGE%:*}"
    port="${TCB_BRIDGE##*:}"
    # bash -c の位置引数($0/$1/$2)経由で渡してクォート事故を避ける
    if timeout 3 bash -c 'exec 3<>"/dev/tcp/$0/$1" && printf "%s\n" "$2" >&3' \
            "$host" "$port" "$url" 2>/dev/null; then
        echo "tcb: opening in host browser: $url" >&2
        exit 0
    fi
    echo "tcb: warning: could not reach the tcb URL bridge at $TCB_BRIDGE" >&2
fi

echo "" >&2
echo "tcb: cannot open a browser inside the container." >&2
echo "tcb: open this URL on the host manually:" >&2
echo "tcb:   $url" >&2
exit 0
